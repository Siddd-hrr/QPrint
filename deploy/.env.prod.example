# Development environment template
# Copy to .env.dev (gitignored) and fill real secrets.

# Container image source (only needed for prod image pulls)
GHCR_OWNER=your-github-username-or-org
IMAGE_TAG=latest

# Exposed ports
GATEWAY_PORT=8080

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Database
POSTGRES_USER=QPrint
POSTGRES_PASSWORD=change-me-dev

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Auth (must be unique per environment)
JWT_SECRET=6oiyPLAnjgo3N0xKoim5oe5V0w2J0LgYVj5XVijGAVQ+LoehnKhmo3bq7eXimTcfk2w5DL/+yRRmm5w6XbwrsA==
JWT_ISSUER=qprint-auth
JWT_AUDIENCE=qprint-api

# Payments
RAZORPAY_KEY_ID=rzp_test_dummy
RAZORPAY_KEY_SECRET=rzp_test_dummy
RAZORPAY_WEBHOOK_SECRET=rzp_test_dummy

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@qprint.app